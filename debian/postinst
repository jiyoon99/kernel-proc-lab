#!/bin/sh
set -e

if command -v dkms >/dev/null 2>&1; then
  if ! dkms status -m kernel-proc-lab -v 0.8.0 >/dev/null 2>&1; then
    dkms add -m kernel-proc-lab -v 0.8.0 || true
  fi
  dkms build -m kernel-proc-lab -v 0.8.0 || true
  dkms install -m kernel-proc-lab -v 0.8.0 || true
fi

if command -v udevadm >/dev/null 2>&1; then
  udevadm control --reload-rules || true
  udevadm trigger --subsystem-match=kernel_proc_lab || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
fi

#DEBHELPER#

exit 0
